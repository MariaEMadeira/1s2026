* {
    margin: 0;
    padding: 0;
}

body {
    font-family: Arial;
    background-color: lightblue;
}

header {
    background-color: blue;
    color: white;
    padding: 20px;
    border-bottom: 5px solid yellow;
}

.nav {
    display: flex;
    justify-content: space-between;
}

nav a {
    color: yellow;
    margin-left: 15px;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    color: red;
}

.hero {
    height: 300px;
    background-color: pink;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 5px dashed purple;
}

.overlay {
    background-color: rgba(0,0,0,0.6);
    color: white;
    padding: 20px;
    border: 3px solid yellow;
}

.intro {
    background-color: lightgreen;
    padding: 30px;
    text-align: center;
    border: 3px solid green;
}

.intro h2 {
    color: purple;
}

.cards {
    background-color: orange;
    padding: 20px;
    border: 5px dotted red;
}

.cards h2 {
    text-align: center;
    color: blue;
}

.grid {
    display: flex;
    gap: 20px;
    margin-top: 20px;
}

.card {
    width: 30%;
    border: 4px solid black;
    text-align: center;
    background-color: white;
}

.card img {
    width: 100%;
    height: 150px;
}


.card h3 {
    color: red;
}

.card p {
    color: green;
    padding: 10px;
}

.card:hover {
    background-color: yellow;
    transform: scale(1.1);
    cursor: pointer;
}

footer {
    background-color: black;
    color: white;
    text-align: center;
    padding: 20px;
    border-top: 5px solid pink;
}
